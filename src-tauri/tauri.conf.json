{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orbita",
  "version": "0.3.0",
  "identifier": "ch.epicube.orbita",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Orbita — Epicube",
        "url": "https://gestion.epicube.ch",
        "width": 1200,
        "height": 800,
        "minWidth": 480,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
